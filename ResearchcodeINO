void handleStart() {
  // 1. Get the values from the web page
  String duration = server.arg("dur");
  String gap = server.arg("gap");
  String variety = server.arg("var");
  String salinity = server.arg("sal");
  String cage = server.arg("cage");

  // 2. Print them to Serial Monitor to check
  Serial.println("--- New Research Started ---");
  Serial.println("Duration: " + duration + " min");
  Serial.println("Variety: " + variety);
  Serial.println("Salinity: " + salinity);

  // 3. Create a header for the SD Card file
  String dataHeader = "Duration,Gap,Variety,Salinity,Cage";
  String dataValues = duration + "," + gap + "," + variety + "," + salinity + "," + cage;
  
  saveToSD(dataHeader);
  saveToSD(dataValues);

  server.send(200, "text/plain", "Research Started for " + variety + ". Recording data...");
}

void setup() {

  Serial.begin(115200);
  WiFi.mode(WIFI_STA);      //esp32 mode
  WiFi.begin(ssid, password);

  //setup sensor
  Wire.begin();             // Start I2C
  dht.begin();              // Start DHT11
  lightMeter.begin();       // Start BH1750
  
    if (!ads.begin()) {
    Serial.println("Failed to initialize ADS1115.");
  }

  // Set the local URL name
  if (MDNS.begin("tomato")) { 
    Serial.println("mDNS started. URL: http://tomato.local");
  }
  server.on("/", handleRoot);
  server.on("/start", handleStart);
  server.begin();

  // Start SD Card (Change '5' to your CS pin if different)
  if(!SD.begin(5)) {
    Serial.println("SD Card Mount Failed!");
  } else {
    Serial.println("SD Card Initialized.");
  }

}

void loop() {
  wificonnect();
  
  if (WiFi.status() == WL_CONNECTED) {
    server.handleClient();
  }
}

void wificonnect() {
  unsigned long currentMillis = millis();
  wl_status_t currentStatus = WiFi.status();

  // 1. Success Message
  if (currentStatus == WL_CONNECTED && lastConnectStatus == false) {
    Serial.println("\nWiFi Connected successfully");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());
    lastConnectStatus = true;
  }

  // 2. Disconnect Message
  if (currentStatus != WL_CONNECTED && lastConnectStatus == true) {
    Serial.println("\nWiFi Disconnected");
    lastConnectStatus = false;
  }

  // 3. Improved Reconnect logic
  if (currentStatus != WL_CONNECTED) {
    if (currentMillis - previousMillis >= interval) {
      previousMillis = currentMillis;

      // ONLY connect if NOT already trying (WL_IDLE_STATUS)
      if (currentStatus != WL_IDLE_STATUS) { 
        Serial.print("Attempting to connect to: ");
        Serial.println(ssid);
        
        WiFi.disconnect(); 
        delay(100); // Increased delay to 100ms to let the radio reset
        WiFi.begin(ssid, password);
      }
    }
  }
}

String getSensorData() {
  // 1. Read DHT11
  float h = dht.readHumidity();
  float t = dht.readTemperature();

  // 2. Read BH1750
  float lux = lightMeter.readLightLevel();

  // 3. Read ADS1115 (Soil & Electrode)
  int16_t soilRaw = ads.readADC_SingleEnded(0); // Soil on A0
  int16_t electRaw = ads.readADC_SingleEnded(1); // Electrode on A1

  // Create a combined text string
  String data = "Temp: " + String(t) + "C, ";
  data += "Humidity: " + String(h) + "%, ";
  data += "Light: " + String(lux) + " lx, ";
  data += "Soil: " + String(soilRaw) + ", ";
  data += "Electrode: " + String(electRaw);

  return data;
}

void saveToSD(String data) {
  // Open the file in APPEND mode (adds to the end of the file)
  File file = SD.open("/data.csv", FILE_APPEND);
  
  if(!file) {
    Serial.println("Failed to open file for appending");
    return;
  }
  
  // Write the data and a new line
  if(file.println(data)) {
    Serial.println("Data saved to SD card");
  } else {
    Serial.println("Save failed");
  }
  
  file.close(); // Always close the file!
}
