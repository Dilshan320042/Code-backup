void handleStart() {
  String cName = server.arg("cage");
  CageState &c = (cName == "Cage 1") ? cage1 : cage2;
  
  // FORCE RESET everything first
  c.isRunning = false; 
  c.isWaiting = false;
  c.lastSampleTime = 0;
  c.lastCountdownMsg = 0;
  
  int dMin = server.arg("delay").toInt();
  c.durationMin = server.arg("dur").toInt();
  c.timeGapSec = server.arg("gap").toInt();
  c.variety = server.arg("var");
  c.salinity = server.arg("sal");

  // Create unique filename
  DateTime now = rtc.now();
  char baseBuf[64];
  sprintf(baseBuf, "/%04d-%02d-%02d_%s_%s_%s", now.year(), now.month(), now.day(), c.name.c_str(), c.variety.c_str(), c.salinity.c_str());
  String finalFileName = String(baseBuf) + ".csv";
  int counter = 1;
  while (SD.exists(finalFileName)) { 
    finalFileName = String(baseBuf) + "_" + String(counter) + ".csv"; 
    counter++; 
  }
  c.currentFileName = finalFileName;

  unsigned long currentMillis = millis();

  if(dMin > 0) {
    c.isWaiting = true;
    c.startTime = currentMillis + ((unsigned long)dMin * 60000);
    addWebLog("[" + c.name + "] DELAY ACTIVE: " + String(dMin) + " min.");
  } else {
    c.isRunning = true;
    c.endTime = currentMillis + ((unsigned long)c.durationMin * 60000);
    addWebLog("Started: " + c.currentFileName);
  }

  updateSystemPower();
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleStop() {
  cage1.isRunning = false; cage1.isWaiting = false;
  cage2.isRunning = false; cage2.isWaiting = false;
  updateSystemPower();
  addWebLog("SYSTEM STOPPED.");
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleDownload() { File f = SD.open(server.arg("f"), FILE_READ); if(f) { server.streamFile(f, "text/csv"); f.close(); } }
void handleDelete() { SD.remove(server.arg("f")); server.sendHeader("Location", "/"); server.send(303); }

void collectData(CageState &c, int cageNum) {
  if (c.isWaiting) {
    if (millis() >= c.startTime) {
      c.isWaiting = false;
      c.isRunning = true;
      c.endTime = millis() + (c.durationMin * 60000);
      updateSystemPower();
      addWebLog("[" + c.name + "] DELAY OVER. Recording...");
    } else if (millis() - c.lastCountdownMsg >= 10000) {
      c.lastCountdownMsg = millis();
      long rem = (c.startTime - millis()) / 1000;
      addWebLog("[" + c.name + "] WAIT: " + String(rem/60) + "m " + String(rem%60) + "s.");
    }
    return;
  }
  if (!c.isRunning) return;
  if (millis() > c.endTime) {
    c.isRunning = false;
    addWebLog("[" + c.name + "] COMPLETED.");
    updateSystemPower();
    return;
  }
  if (millis() - c.lastSampleTime >= (c.timeGapSec * 1000)) {
    c.lastSampleTime = millis();
    DateTime now = rtc.now();
    String ts = String(now.hour()) + ":" + (now.minute()<10?"0":"") + String(now.minute()) + ":" + (now.second()<10?"0":"") + String(now.second());
    
    float t = (cageNum == 1) ? dht1.readTemperature() : dht2.readTemperature();
    float h = (cageNum == 1) ? dht1.readHumidity() : dht2.readHumidity();
    
    // SENSOR ADDRESS MAPPING
    // Cage 1 = 0x5C (3.3V Pin), Cage 2 = 0x23 (Empty)
    float l = (cageNum == 1) ? lightMeter1.readLightLevel() : lightMeter2.readLightLevel();
    
    int re = (cageNum == 1) ? ads.readADC_SingleEnded(0) : ads.readADC_SingleEnded(1);
    int rs = (cageNum == 1) ? ads.readADC_SingleEnded(2) : ads.readADC_SingleEnded(3);
    File f = SD.open(c.currentFileName, FILE_APPEND);
    if (f) {
      if (f.size() == 0) f.println("Time,Variety,Salinity,Temp,Hum,Lux,ElecMV,SoilMV");
      f.printf("%s,%s,%s,%.1f,%.1f,%.0f,%.1f,%.1f\n", ts.c_str(), c.variety.c_str(), c.salinity.c_str(), t, h, l, re*0.125, rs*0.125);
      f.close();
      String msg = "[" + c.name + "] " + ts + " | Temp:" + String(t,1) + " Hum:" + String(h,0) + "% Sal:" + c.salinity + " Lux:" + String(l,0) + " Elec:" + String(re*0.125,0) + "mV";
      addWebLog(msg);
    }
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(BUILTIN_LED, OUTPUT);
  pinMode(POWER_SWITCH_PIN, OUTPUT); 
  digitalWrite(POWER_SWITCH_PIN, HIGH); 
  Wire.begin(I2C_SDA, I2C_SCL); 
  rtc.begin(); dht1.begin(); dht2.begin(); ads.begin();

  // BH1750 SETUP: Sensor 1 (0x5C) has 3.3V connection. Sensor 2 (0x23) is default.
  lightMeter1.begin(BH1750::CONTINUOUS_HIGH_RES_MODE, 0x5C, &Wire);
  lightMeter2.begin(BH1750::CONTINUOUS_HIGH_RES_MODE, 0x23, &Wire);

  SPI.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS); 
  SD.begin(SD_CS);
  WiFi.begin(ssid, password);
  MDNS.begin("tomato");
  server.on("/", handleRoot);
  server.on("/start", handleStart);
  server.on("/stop", handleStop);
  server.on("/download", handleDownload);
  server.on("/delete", handleDelete);
  server.on("/logs", [](){
    String l = "";
    for(int i=MAX_WEB_LOGS-1; i>=0; i--) {
      int idx = (webLogIndex + i) % MAX_WEB_LOGS;
      if (webLogs[idx] != "") l += webLogs[idx];
    }
    server.send(200, "text/plain", l);
  });
  
  server.on("/status", [](){
    auto getPerc = [](CageState &c) {
      if (c.isRunning) {
        if (millis() >= c.endTime) return 100;
        unsigned long total = (unsigned long)c.durationMin * 60000;
        unsigned long elapsed = millis() - (c.endTime - total);
        int p = (int)((elapsed * 100) / total);
        return (p > 100) ? 100 : (p < 0 ? 0 : p);
      }
      int lastIdx = (webLogIndex + MAX_WEB_LOGS - 1) % MAX_WEB_LOGS;
      if (webLogs[lastIdx].indexOf("COMPLETED") != -1 && webLogs[lastIdx].indexOf(c.name) != -1) return 100;
      return 0;
    };
    server.send(200, "application/json", "{\"p1\":" + String(getPerc(cage1)) + ",\"p2\":" + String(getPerc(cage2)) + "}");
  });
  
  server.begin();
}

void loop() {
  wificonnect(); 
  server.handleClient();
  collectData(cage1, 1);
  collectData(cage2, 2);
}