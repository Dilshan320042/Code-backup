// --- 1. NETWORK & SYSTEM CONFIG ---
const char* ssid = "Samsung galaxy s24";
const char* password = "Dilshan@123456";
unsigned long previousMillis = 0;
const long interval = 30000; 
bool lastConnectStatus = false; 

// --- 2. HARDWARE PINS ---
#define I2C_SDA 8
#define I2C_SCL 9
#define SD_CS 10
#define SD_MOSI 11
#define SD_MISO 13
#define SD_SCK 12
#define DHT1_PIN 4
#define DHT2_PIN 6
#define DHTTYPE DHT11
#define POWER_SWITCH_PIN 5 
#define BUILTIN_LED 2 

// --- 3. OBJECTS ---
DHT dht1(DHT1_PIN, DHTTYPE);
DHT dht2(DHT2_PIN, DHTTYPE);
Adafruit_ADS1115 ads; 
BH1750 lightMeter1; 
BH1750 lightMeter2; 
RTC_DS3231 rtc;
WebServer server(80); 

// --- 4. SYSTEM STATE ---
#define MAX_WEB_LOGS 15
String webLogs[MAX_WEB_LOGS];
int webLogIndex = 0;

struct CageState {
  String name;
  bool isRunning;
  bool isWaiting;
  unsigned long startTime; 
  unsigned long endTime;   
  unsigned long lastSampleTime;
  unsigned long lastCountdownMsg;
  int durationMin;
  int timeGapSec;
  String variety;
  String salinity;
  String currentFileName; 
};

CageState cage1 = {"Cage1", false, false, 0, 0, 0, 0, 0, 0, "", "", ""};
CageState cage2 = {"Cage2", false, false, 0, 0, 0, 0, 0, 0, "", "", ""};

// --- 5. POWER LOGIC HELPER ---
void updateSystemPower() {
  if (cage1.isRunning || cage2.isRunning) {
    digitalWrite(POWER_SWITCH_PIN, LOW); // Battery Mode
  } else {
    digitalWrite(POWER_SWITCH_PIN, HIGH); // Adapter Mode
  }
}

void addWebLog(String msg) {
  webLogs[webLogIndex] = msg + "<br>";
  webLogIndex = (webLogIndex + 1) % MAX_WEB_LOGS;
  Serial.println(msg); 
}

void wificonnect() {
  unsigned long currentMillis = millis();
  wl_status_t currentStatus = WiFi.status();
  if (currentStatus == WL_CONNECTED && lastConnectStatus == false) {
    addWebLog("WiFi Connected: " + WiFi.localIP().toString());
    lastConnectStatus = true;
  }
  if (currentStatus != WL_CONNECTED && lastConnectStatus == true) {
    addWebLog("SYSTEM: WiFi Connection Lost.");
    lastConnectStatus = false;
  }
  if (currentStatus != WL_CONNECTED) {
    if (currentMillis - previousMillis >= interval) {
      previousMillis = currentMillis;
      if (currentStatus != WL_IDLE_STATUS) { 
        WiFi.disconnect(); 
        delay(100); 
        WiFi.begin(ssid, password);
      }
    }
  }
}

